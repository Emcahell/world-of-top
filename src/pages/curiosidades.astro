        </div>
      </section>

      <!-- Fe cristiana -->
      <section class="mb-20">
        <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-8 items-center">
          <div class="flex justify-center">
            <img src={silenceImg.src} alt="Torres del Silencio" loading="lazy" class="w-full max-w-[280px] rounded-2xl shadow-xl border border-white/10 hover:scale-105 transition-transform duration-300" />
          </div>
          <div class="lore-entry">
            <h3 class="text-xl md:text-2xl font-bold text-[#d62420] mb-4 uppercase tracking-wide">Fe y espiritualidad</h3>
            <div class="lore-content bg-[#2a2526]/80 backdrop-blur-sm rounded-xl p-6 md:p-8 border border-white/5" set:html={feCristianaHtml} />
          </div>
        </div>
      </section>

    </div>
  </main>
</Layout>

