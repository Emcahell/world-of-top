---
import ImgVzla from "../../assets/vzla.webp";
---

<footer class="relative bg-[#1a1819] font-roboto overflow-hidden">
    <!-- Gradient top border -->
    <div
        class="h-0.5 bg-gradient-to-r from-[#d62420] via-[#ffd800] to-[#4545dd]"
    >
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
        <!-- Title -->
        <div class="text-center mb-10">
            <h3
                class="text-sm md:text-base font-bold uppercase tracking-[0.25em] text-[#ffd800]/80 mb-2"
            >
                Welcome to the World of
            </h3>
            <span
                class="text-lg md:text-xl font-bold uppercase tracking-[0.15em] text-white"
            >
                Twenty One Pilots
            </span>
        </div>

        <!-- Navigation Links -->
        <nav
            class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-10 pb-8 border-b border-white/10"
        >
            <a
                href="/"
                class="text-gray-400 text-sm uppercase tracking-wider hover:text-[#ffd800] transition-colors duration-300"
                >Inicio</a
            >
            <a
                href="/origen"
                class="text-gray-400 text-sm uppercase tracking-wider hover:text-[#ffd800] transition-colors duration-300"
                >Origen</a
            >
            <a
                href="/discografia"
                class="text-gray-400 text-sm uppercase tracking-wider hover:text-[#ffd800] transition-colors duration-300"
                >Discografía</a
            >
            <a
                href="/lore"
                class="text-gray-400 text-sm uppercase tracking-wider hover:text-[#ffd800] transition-colors duration-300"
                >Lore</a
            >
            <a
                href="/curiosidades"
                class="text-gray-400 text-sm uppercase tracking-wider hover:text-[#ffd800] transition-colors duration-300"
                >Curiosidades</a
            >
            <a
                href="/referencias"
                class="text-gray-400 text-sm uppercase tracking-wider hover:text-[#ffd800] transition-colors duration-300"
                >Referencias</a
            >
        </nav>

        <!-- Credits Section -->
        <div class="text-center mb-8">
            <p class="text-gray-400 text-sm mb-4">
                Hecho con
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="#d62420"
                    class="inline-block align-middle mx-1"
                >
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path
                        d="M6.979 3.074a6 6 0 0 1 4.988 1.425l.037 .033l.034 -.03a6 6 0 0 1 4.733 -1.44l.246 .036a6 6 0 0 1 3.364 10.008l-.18 .185l-.048 .041l-7.45 7.379a1 1 0 0 1 -1.313 .082l-.094 -.082l-7.493 -7.422a6 6 0 0 1 3.176 -10.215z"
                    ></path>
                </svg>
                por
            </p>
        </div>

        <!-- Creators Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
            <!-- Developer -->
            <div
                class="bg-[#231f20]/80 rounded-xl p-5 border border-white/5 text-center"
            >
                <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">
                    Desarrollador
                </p>
                <p class="text-white font-bold text-lg mb-3">Emmanuell</p>
                <div class="flex justify-center gap-4">
                    <a
                        href="https://instagram.com/emcahell"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-400 hover:text-[#ffd800] transition-colors duration-300"
                        aria-label="Instagram"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="22"
                            height="22"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"
                            ></path>
                            <path
                                d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z"
                            ></path>
                            <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"
                            ></path>
                            <path d="M16.5 7.5l0 .01"></path>
                        </svg>
                    </a>
                    <a
                        href="https://github.com/Emcahell"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-400 hover:text-[#ffd800] transition-colors duration-300"
                        aria-label="GitHub"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="22"
                            height="22"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"
                            ></path>
                            <path
                                d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Collaborator -->
            <div
                class="bg-[#231f20]/80 rounded-xl p-5 border border-white/5 text-center"
            >
                <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">
                    Colaboración
                </p>
                <p class="text-white font-bold text-lg mb-3">Maruu Aranguren</p>
                <div class="flex justify-center gap-4">
                    <a
                        href="https://www.facebook.com/marialis.aranguren.14?mibextid=ZbWKwL"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-400 hover:text-[#ffd800] transition-colors duration-300"
                        aria-label="Facebook"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="22"
                            height="22"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"
                            ></path>
                            <path
                                d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
        </div>

        <!-- Disclaimer -->
        <p
            class="text-center! text-gray-500 text-xs leading-relaxed mb-8 max-w-2xl mx-auto"
        >
            Este no es el sitio web oficial de Twenty One Pilots. Esta página
            fue creada por un fan para mostrar la historia que la banda cuenta a
            través de su música.
        </p>

        <!-- References Link -->
        <div class="text-center mb-8">
            <span class="text-gray-400 text-sm mb-2">
                ¿Quieres consultar las fuentes de información?
            </span>
            <br />
            <a
                href="/referencias"
                class="inline-block text-[#ffd800] text-sm font-semibold uppercase tracking-wider hover:text-white transition-colors duration-300 border-b border-[#ffd800]/40 hover:border-white/40 pb-0.5"
            >
                Ver Referencias →
            </a>
        </div>

        <!-- Made In Venezuela -->
        <div
            class="flex flex-col items-center gap-3 pt-6 border-t border-white/10"
        >
            <p class="text-xs text-gray-500 uppercase tracking-widest">
                Made In
            </p>
            <div class="flex items-center gap-3">
                <img
                    src={ImgVzla.src}
                    alt="Venezuela"
                    class="w-10 h-7 object-cover"
                />
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="#d62420"
                >
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                    <path
                        d="M6.979 3.074a6 6 0 0 1 4.988 1.425l.037 .033l.034 -.03a6 6 0 0 1 4.733 -1.44l.246 .036a6 6 0 0 1 3.364 10.008l-.18 .185l-.048 .041l-7.45 7.379a1 1 0 0 1 -1.313 .082l-.094 -.082l-7.493 -7.422a6 6 0 0 1 3.176 -10.215z"
                    ></path>
                </svg>
            </div>
            <p class="text-gray-600 text-xs">
                Para toda la comunidad de habla hispana fan de Twenty One Pilots
            </p>
        </div>

        <!-- Copyright -->
        <p class="text-center text-gray-600 text-xs mt-6 tracking-wide">
            World of Twenty One Pilots &nbsp;·&nbsp; 2025
        </p>
    </div>
</footer>
