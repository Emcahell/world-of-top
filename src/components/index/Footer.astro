---
import ImgVzla from "../../assets/vzla.webp";
---

<footer
    class="bg-(--bg-Dark) px-4 md:px-8 py-4 flex flex-col items-center justify-center"
>
    <div class="max-w-5xl mx-auto">
        <p class="text-(--White)">2025 World of Top</p>

        <p class="flex items-center text-white gap-4">
            <span class="font-bold"> Made In </span>
            <img src={ImgVzla.src} alt="Vzla" class="w-8 h-8" />
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="fill-white"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                <path
                    d="M6.979 3.074a6 6 0 0 1 4.988 1.425l.037 .033l.034 -.03a6 6 0 0 1 4.733 -1.44l.246 .036a6 6 0 0 1 3.364 10.008l-.18 .185l-.048 .041l-7.45 7.379a1 1 0 0 1 -1.313 .082l-.094 -.082l-7.493 -7.422a6 6 0 0 1 3.176 -10.215z"
                ></path></svg
            >
        </p>
    </div>
</footer>
