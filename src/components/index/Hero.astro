---
import ImgBoys from "../../assets/boys-hero.webp";
import ImgDesktopHero from "../../assets/desktop-hero.webp";
import ImgMobileHero from "../../assets/mobile-hero.webp";
---

<section
    class="relative w-full h-screen min-h-[600px] flex flex-col justify-between overflow-hidden bg-[var(--bg-Dark)] font-[var(--Roboto)]"
>
    <!-- Background Image -->
    <picture class="absolute inset-0 z-0">
        <source media="(min-width: 768px)" srcset={ImgDesktopHero.src} />
        <img
            src={ImgMobileHero.src}
            alt="Hero Background"
            class="w-full h-full object-cover object-center opacity-80"
        />
    </picture>

    <!-- Boys Image (Left Side) -->
    <img
        src={ImgBoys.src}
        alt="Tyler and Josh"
        class="absolute z-20 w-[240px] sm:w-[300px] md:w-[360px] top-[30%] md:top-auto md:bottom-[15%] left-[2%] md:left-[5%] object-contain pointer-events-none drop-shadow-xl [mask-image:linear-gradient(black_80%,transparent)]"
    />

    <!-- Header Content -->
    <div
        class="relative z-10 flex flex-col items-center justify-start pt-16 md:pt-20 flex-grow w-full px-4"
    >
        <h1
            class="text-[var(--Red)] font-bold text-3xl md:text-5xl lg:text-6xl uppercase tracking-widest mb-4 text-center"
        >
            Bienvenido al mundo
        </h1>
        <h2
            class="text-[var(--Red)] font-bold text-2xl md:text-4xl uppercase tracking-[0.2em] mb-8 text-center"
        >
            De
        </h2>

        <img
            src="/TWENTYONEPILOTS.svg"
            alt="twenty one pilots"
            class="w-[90%] md:w-[80%] max-w-[900px] h-auto drop-shadow-2xl"
        />
    </div>

    <!-- Navigation -->
    <nav class="relative z-10 w-full px-8 md:px-16 pb-14">
        <div
            class="border-t-[1px] border-[var(--Gray)] pt-8 flex flex-col md:flex-row flex-wrap justify-between items-center gap-6"
        >
            <a
                href="/origen"
                class="text-[var(--White)] font-bold uppercase tracking-widest text-sm md:text-base hover:text-[var(--Yellow)] transition-colors"
                >Origen de la banda</a
            >
            <a
                href="/discografia"
                class="text-[var(--White)] font-bold uppercase tracking-widest text-sm md:text-base hover:text-[var(--Yellow)] transition-colors"
                >Eras y álbumes</a
            >
            <a
                href="/lore"
                class="text-[var(--White)] font-bold uppercase tracking-widest text-sm md:text-base hover:text-[var(--Yellow)] transition-colors"
                >Lore</a
            >
            <a
                href="/curiosidades"
                class="text-[var(--White)] font-bold uppercase tracking-widest text-sm md:text-base hover:text-[var(--Yellow)] transition-colors"
                >Curiosidades</a
            >
        </div>
    </nav>
</section>
