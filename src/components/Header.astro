---
import HeaderReact from "./HeaderReact.jsx";
import ImgLogoBlurryface from "../assets/logos-y-portadas/Twenty-One-Pilots-Logo-2015-blurryface.png";
import ImgLogoTrench from "../assets/logos-y-portadas/Twenty-One-Pilots-Logo-2019-trench.png";
import ImgLogoClancy from "../assets/logos-y-portadas/Twenty-One-Pilots-Logo-clancy.png";
import ImgLogoRab from "../assets/logos-y-portadas/twenty-one-pilots-logo-rab.png";
import ImgBg from "../assets/header.webp";
---

<HeaderReact
    client:idle
    imgBg={ImgBg.src}
    imgLogoClancy={ImgLogoClancy.src}
    imgLogoClancyYellow="/logo-clancy-yellow.png"
    imgLogoTwentyOnePilots="/TWENTYONEPILOTS.svg"
    imgLogoBlurryface={ImgLogoBlurryface.src}
    imgLogoTrench={ImgLogoTrench.src}
    imgLogoRab={ImgLogoRab.src}
/>
